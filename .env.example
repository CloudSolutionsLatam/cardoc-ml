# Plantilla de variables de entorno. Copiar a .env (gitignored) para desarrollo local.
# En Catalyst los secretos viven en Console → Environment Variables, NUNCA en el repo.

# Persistencia: "datastore" usa Catalyst DataStore (catalyst.initialize por request).
# Cualquier otro valor → repos in-memory sembrados (dev/local).
CARDOC_PERSISTENCE=memory

# Cliente CRM: "zoho" usa el adapter HTTP real (requiere Connection); otro → MockCrmClient.
CARDOC_CRM_MODE=mock

# Fuente de informes: "creator" usa Zoho Creator/WorkDrive real; otro → MockReportsSource.
CARDOC_REPORTS_MODE=mock

# Caps por defecto (requests por ventana) si el consumidor no tiene config propia.
CARDOC_CAP_DEFAULT_HOUR=1000
CARDOC_CAP_DEFAULT_DAY=10000
CARDOC_CAP_DEFAULT_WEEK=50000

# Zoho CRM (cuando CARDOC_CRM_MODE=zoho). El access token real lo resuelve la
# Catalyst Connection en runtime; acá solo el dominio de API por si se requiere.
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com
ZOHO_CRM_CONNECTOR_NAME=zoho_crm_conn
