# Plantilla de variables de entorno. Copiar a .env (gitignored) para desarrollo local.
# En Catalyst los secretos viven en Console → Environment Variables, NUNCA en el repo.

# Persistencia: "datastore" usa Catalyst DataStore (catalyst.initialize por request).
# Cualquier otro valor → repos in-memory sembrados (dev/local).
CARDOC_PERSISTENCE=memory

# Cliente CRM: "zoho" usa el adapter HTTP real (requiere Connection); otro → MockCrmClient.
CARDOC_CRM_MODE=mock

# Fuente de informes: "creator" usa Zoho Creator/WorkDrive real; otro → MockReportsSource.
CARDOC_REPORTS_MODE=mock

# Caps por defecto (requests por ventana) si el consumidor no tiene config propia.
CARDOC_CAP_DEFAULT_HOUR=1000
CARDOC_CAP_DEFAULT_DAY=10000
CARDOC_CAP_DEFAULT_WEEK=50000

# Zoho CRM (cuando CARDOC_CRM_MODE=zoho). En runtime el access token lo resuelve el
# self-client vía SDK de Catalyst con estas credenciales (secretos: NO commitear valores).
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com
ZOHO_CRM_CONNECTOR_NAME=zoho_crm_conn
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
# Solo para el script de prueba `pnpm zoho:check` (refresh por HTTP directo desde la máquina):
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
# id de la Cuenta "ML" del CRM — requerido solo por `pnpm zoho:check --write`
CARDOC_TEST_ACCOUNT_ID=

# Integración OUTBOUND con ML (MLCenter / AutoCheck) — notificar cambios de estado.
# CARDOC_ML_MODE: "http" usa el adapter real (MlCenterHttpClient); otro → MockMlCenterClient.
CARDOC_ML_MODE=mock
MLCENTER_BASE_URL=https://www.mlcenter.com.uy/ApiMiAutoTesting
MLCENTER_USER=
MLCENTER_PASSWORD=
# Shared secret del webhook CRM → Catalyst (rutas /v1/internal/*).
INTERNAL_WEBHOOK_SECRET=dev-internal-secret
