# Plantilla de variables de entorno. Copiar a .env (gitignored) para desarrollo local.
# En Catalyst los SECRETOS viven en Console → Environment Variables, NUNCA en el repo.
# El comentario de cada variable lista sus VALORES POSIBLES; el valor mostrado es el DEFAULT del código.

# ──────────────────────────────────────────────────────────────
# Modos de ejecución (runtime)
# ──────────────────────────────────────────────────────────────
# datastore = Catalyst DataStore | cualquier otro valor = repos in-memory sembrados (dev/local)
CARDOC_PERSISTENCE=memory

# zoho = adapter HTTP real (requiere ZOHO_* self-client) | otro = MockCrmClient
CARDOC_CRM_MODE=mock

# creator = Zoho Creator/WorkDrive real (requiere CREATOR_*) | otro = MockReportsSource
CARDOC_REPORTS_MODE=mock

# http = MlCenterHttpClient real (requiere MLCENTER_*) | log = LoggingMlCenterClient (loggea el payload, NO llama a ML) | otro = MockMlCenterClient
CARDOC_ML_MODE=mock

# ──────────────────────────────────────────────────────────────
# Caps por defecto (requests por ventana, si el consumidor no tiene fila propia en consumer_caps)
# ──────────────────────────────────────────────────────────────
# entero
CARDOC_CAP_DEFAULT_HOUR=1000

# entero
CARDOC_CAP_DEFAULT_DAY=10000

# entero
CARDOC_CAP_DEFAULT_WEEK=50000

# ──────────────────────────────────────────────────────────────
# Zoho CRM · self-client OAuth (cuando CARDOC_CRM_MODE=zoho). SECRETOS: NO commitear valores
# ──────────────────────────────────────────────────────────────
# URL del dominio de API de Zoho
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com

# nombre del conector self-client
ZOHO_CRM_CONNECTOR_NAME=zoho_crm_conn

# SECRETO — self-client OAuth (formato 1000.XXXX)
ZOHO_CLIENT_ID=

# SECRETO — self-client OAuth
ZOHO_CLIENT_SECRET=

# SECRETO — refresh token de larga vida (el SDK renueva el access token)
ZOHO_REFRESH_TOKEN=

# OPCIONAL — access token directo (testing/token corto). Si está, saltea el self-client
ZOHO_CRM_ACCESS_TOKEN=

# ──────────────────────────────────────────────────────────────
# Zoho Creator / WorkDrive · informe + PDF (cuando CARDOC_REPORTS_MODE=creator). SECRETOS
# ──────────────────────────────────────────────────────────────
# SECRETO — Endpoint URL de la Custom API GET_INSPECTION_REPORT_DETAIL con la publickey embebida
CREATOR_REPORT_DETAIL_URL=

# SECRETO FUERTE — clave AES que acuña el token de sesión (zoho.encryption.aesEncode)
CREATOR_TOKEN_KEY=

# id del cliente embebido en el mini-JWT del token de sesión
CREATOR_TOKEN_CLIENT_ID=cardoc

# publickey (default) | oauth (a futuro, mismo self-client del CRM)
CREATOR_AUTH_MODE=publickey

# ──────────────────────────────────────────────────────────────
# ML / MLCenter (AutoCheck) OUTBOUND · notificación de estado (cuando CARDOC_ML_MODE=http). SECRETOS
# ──────────────────────────────────────────────────────────────
# .../ApiMiAutoTesting (testing) | .../apimiauto (prod)
MLCENTER_BASE_URL=https://www.mlcenter.com.uy/ApiMiAutoTesting

# SECRETO — Usuario para authenticatecardoc
MLCENTER_USER=

# SECRETO — Password para authenticatecardoc
MLCENTER_PASSWORD=

# ──────────────────────────────────────────────────────────────
# Rutas internas (CRM → Catalyst)
# ──────────────────────────────────────────────────────────────
# shared-secret del header x-internal-secret. SETEAR uno REAL en prod (el fallback es solo dev)
INTERNAL_WEBHOOK_SECRET=dev-internal-secret

# ──────────────────────────────────────────────────────────────
# Dev server local (scripts/dev-server.mjs)
# ──────────────────────────────────────────────────────────────
# puerto del server local (3030 por defecto; 3000 suele estar tomado por el ERP)
PORT=3030

# ──────────────────────────────────────────────────────────────
# Scripts de verificación de CRM (pnpm zoho:check)
# ──────────────────────────────────────────────────────────────
# URL de accounts para el refresh directo por HTTP
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com

# id de la Cuenta ML del CRM (requerido solo por zoho:check --write)
CARDOC_TEST_ACCOUNT_ID=

# ──────────────────────────────────────────────────────────────
# Ops · Seed del DataStore por REST (scripts/seed-datastore.mjs). Token con scope ZohoCatalyst
# ──────────────────────────────────────────────────────────────
# self-client (fallback a ZOHO_CLIENT_ID si vacío)
CATALYST_CLIENT_ID=

# self-client (fallback a ZOHO_CLIENT_SECRET si vacío)
CATALYST_CLIENT_SECRET=

# SECRETO — refresh token scope ZohoCatalyst.tables.rows.CREATE/READ + tables.READ (cuenta OWNER del proyecto)
CATALYST_REFRESH_TOKEN=

# OPCIONAL — access token directo one-shot (~1h), alternativa al refresh
CATALYST_ACCESS_TOKEN=

# id del proyecto Catalyst (ML)
CATALYST_PROJECT_ID=57305000000083001

# DC del self-client para el refresh del token
CATALYST_ACCOUNTS_URL=https://accounts.zoho.com

# origin de la API admin de Catalyst
CATALYST_API_ORIGIN=https://api.catalyst.zoho.com

