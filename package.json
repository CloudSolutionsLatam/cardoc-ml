{
  "name": "cardoc",
  "version": "0.0.0",
  "private": true,
  "description": "API en Zoho Catalyst para automotoras: opportunity-contact (CRM) + informes de revisión (Creator/WorkDrive). Monorepo pnpm (apps + packages).",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.13.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.14.0",
    "typescript": "5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
